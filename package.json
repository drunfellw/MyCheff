{
  "name": "mycheff-frontend",
  "version": "1.0.0",
  "description": "Professional Recipe App - Cross-platform mobile application built with React Native and Expo",
  "keywords": ["react-native", "expo", "typescript", "recipe", "mobile", "cross-platform"],
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios",
    "build:web": "expo build:web",
    "publish": "expo publish",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "clean": "expo r -c",
    "eject": "expo eject"
  },
  "dependencies": {
    "expo": "~50.0.14",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-vector-icons": "^10.0.3",
    "@expo/vector-icons": "^14.0.0",
    "react-native-responsive-dimensions": "^3.1.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "typescript": "^5.1.3"
  },
  "author": {
    "name": "MyCheff Team",
    "email": "team@mycheff.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mycheff/mycheff-frontend.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mycheff/mycheff-frontend/issues"
  },
  "homepage": "https://mycheff.com",
  "private": false,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
